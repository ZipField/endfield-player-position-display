<Window x:Class="endfield_player_position_display.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="520"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterOwner"
        AllowsTransparency="False"
        Background="#08111C">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#F7FAFC" />
            <Setter Property="BorderBrush" Value="#CAD5E0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="#F7FAFC" />
            <Setter Property="BorderBrush" Value="#CAD5E0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#1F6FEB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1F6FEB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Foreground" Value="#1F2937" />
        </Style>
    </Window.Resources>

    <Grid Background="#08111C" ClipToBounds="True">
        <Image Source="Assets/endfield-login-bg.jpg"
               Stretch="UniformToFill"
               Opacity="0.9" />
        <Rectangle Fill="#9908111C" />

        <Grid Margin="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="36,0,4,18">
                <TextBlock Text="明日方舟：终末地"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <TextBlock Text="登录森空岛账号以连接坐标同步"
                           FontSize="14"
                           Foreground="#D9E4F2"
                           Margin="0,8,0,0" />
            </StackPanel>

            <Border Grid.Column="0"
                    Background="#EEF7FAFC"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="22"
                    VerticalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="登录"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <TextBlock Text="选择一种方式获取 token"
                                   FontSize="12"
                                   Foreground="#667085"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <TabControl Grid.Row="1"
                                x:Name="LoginTabs"
                                SelectionChanged="LoginTabsSelectionChanged">
                        <TabItem Header="扫码">
                            <Grid Margin="0,18,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Width="238"
                                        Height="238"
                                        Background="White"
                                        BorderBrush="#D8E0EA"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        HorizontalAlignment="Center">
                                    <Image x:Name="QrImage"
                                           Width="210"
                                           Height="210"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                </Border>
                                <Button Grid.Row="1"
                                        x:Name="RefreshQrButton"
                                        Content="刷新二维码"
                                        Width="110"
                                        HorizontalAlignment="Center"
                                        Click="RefreshQrButtonClick"
                                        Margin="0,16,0,0" />
                            </Grid>
                        </TabItem>

                        <TabItem Header="验证码">
                            <StackPanel Margin="0,18,0,0">
                                <TextBlock Text="手机号" Foreground="#344054" Margin="0,0,0,6" />
                                <TextBox x:Name="CodePhoneTextBox"
                                         MaxLength="11"
                                         InputScope="TelephoneNumber"
                                         PreviewTextInput="DigitsOnlyPreviewTextInput"
                                         TextChanged="DigitsOnlyTextChanged"
                                         Margin="0,0,0,12" />
                                <TextBlock Text="验证码" Foreground="#344054" Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="112" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CodeTextBox"
                                             MaxLength="6"
                                             InputScope="Number"
                                             PreviewTextInput="DigitsOnlyPreviewTextInput"
                                             TextChanged="DigitsOnlyTextChanged"
                                             Margin="0,0,10,0" />
                                    <Button x:Name="SendCodeButton"
                                            Grid.Column="1"
                                            Content="发送验证码"
                                            Click="SendCodeButtonClick" />
                                </Grid>
                                <Button x:Name="CodeLoginButton"
                                        Content="登录"
                                        HorizontalAlignment="Stretch"
                                        Click="CodeLoginButtonClick" />
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="密码">
                            <StackPanel Margin="0,18,0,0">
                                <TextBlock Text="手机号" Foreground="#344054" Margin="0,0,0,6" />
                                <TextBox x:Name="PasswordPhoneTextBox"
                                         MaxLength="11"
                                         InputScope="TelephoneNumber"
                                         PreviewTextInput="DigitsOnlyPreviewTextInput"
                                         TextChanged="DigitsOnlyTextChanged"
                                         Margin="0,0,0,12" />
                                <TextBlock Text="密码" Foreground="#344054" Margin="0,0,0,6" />
                                <PasswordBox x:Name="PasswordBox" Margin="0,0,0,16" />
                                <Button x:Name="PasswordLoginButton"
                                        Content="登录"
                                        HorizontalAlignment="Stretch"
                                        Click="PasswordLoginButtonClick" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <TextBlock Grid.Row="2"
                               x:Name="StatusText"
                               TextWrapping="Wrap"
                               Foreground="#344054"
                               Margin="0,16,0,12" />

                    <Button Grid.Row="3"
                            Content="取消"
                            Width="82"
                            HorizontalAlignment="Right"
                            Background="#F7FAFC"
                            Foreground="#344054"
                            BorderBrush="#CAD5E0"
                            Click="CancelButtonClick" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
