<Window x:Class="endfield_player_position_display.TokenManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="token 管理"
        Width="720"
        Height="520"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F7F9FC">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="AddTokenButton" Content="添加" Width="72" Height="30" Click="AddTokenButtonClick" Margin="0,0,8,0" />
            <Button x:Name="RemoveTokenButton" Content="移除选中" Width="86" Height="30" Click="RemoveTokenButtonClick" Margin="0,0,8,0" />
            <Button x:Name="RefreshButton" Content="刷新" Width="72" Height="30" Click="RefreshButtonClick" />
        </StackPanel>

        <ListBox Grid.Row="1"
                 x:Name="TokenListBox"
                 DisplayMemberPath="DisplayText"
                 FontFamily="Consolas"
                 FontSize="12"
                 Background="White"
                 Foreground="#1F2328" />

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" Foreground="#3C4043" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="关闭" Width="72" Height="30" Click="CloseButtonClick" />
        </Grid>
    </Grid>
</Window>
